{
  "name": "perler-beads",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "perler-beads",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@perler/api",
      "version": "0.0.0"
    },
    "apps/miniapp": {
      "name": "@perler/miniapp",
      "version": "0.0.0"
    },
    "node_modules/@perler/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@perler/miniapp": {
      "resolved": "apps/miniapp",
      "link": true
    },
    "node_modules/@perler/pattern-core": {
      "resolved": "packages/pattern-core",
      "link": true
    },
    "node_modules/@perler/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/zod": {
      "version": "4.3.6",
      "resolved": "https://registry.npmjs.org/zod/-/zod-4.3.6.tgz",
      "integrity": "sha512-rftlrkhHZOcjDwkGlnUtZZkvaPHCsDATp4pGpuOOMDaTdDDXF91wuVDJoWoPsKX/3YPQ5fHuF3STjcYyKr+Qhg==",
      "license": "MIT",
      "funding": {
        "url": "https://github.com/sponsors/colinhacks"
      }
    },
    "packages/pattern-core": {
      "name": "@perler/pattern-core",
      "version": "0.0.0",
      "dependencies": {
        "@perler/shared": "0.0.0"
      }
    },
    "packages/shared": {
      "name": "@perler/shared",
      "version": "0.0.0",
      "dependencies": {
        "zod": "^4.3.6"
      }
    }
  }
}
