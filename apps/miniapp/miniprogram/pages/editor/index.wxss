.editor-page {
  padding-top: 36rpx;
}

.editor-loading {
  padding: 60rpx 0;
  color: #7a685c;
  font-size: 24rpx;
}

.editor-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.editor-tool {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(43, 36, 29, 0.06);
  color: #72594b;
  font-size: 22rpx;
}

.editor-tool-active {
  background: #1d6f5f;
  color: #fbf7f1;
}

.editor-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.editor-action {
  border-radius: 20rpx;
  background: rgba(43, 36, 29, 0.06);
  color: #2b241d;
  font-size: 24rpx;
  border: none;
}

.editor-action-primary {
  background: #1d6f5f;
  color: #fbf7f1;
}

.editor-canvas-wrap {
  width: 100%;
  margin-bottom: 28rpx;
}

.editor-canvas {
  display: inline-flex;
  flex-direction: column;
  padding: 12rpx;
  border-radius: 24rpx;
  background: rgba(43, 36, 29, 0.06);
}

.editor-row {
  display: flex;
}

.editor-cell {
  width: 24rpx;
  height: 24rpx;
  border: 1rpx solid rgba(43, 36, 29, 0.08);
  box-sizing: border-box;
}

.editor-palette {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.editor-palette-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(251, 247, 241, 0.84);
}

.editor-palette-item-active {
  outline: 2rpx solid #1d6f5f;
}

.editor-palette-swatch {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(43, 36, 29, 0.1);
}

.editor-palette-meta {
  flex: 1;
  font-size: 24rpx;
}

.editor-palette-kind {
  margin-top: 4rpx;
  color: #7a685c;
  font-size: 20rpx;
}
