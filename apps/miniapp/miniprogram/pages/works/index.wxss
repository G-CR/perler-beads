.works-page {
  padding-top: 36rpx;
}

.works-refresh {
  border-radius: 999rpx;
  background: rgba(29, 111, 95, 0.08);
  color: #1d6f5f;
  border: none;
}

.works-filter {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(43, 36, 29, 0.06);
  color: #72594b;
  font-size: 24rpx;
}

.works-filter-active {
  background: #1d6f5f;
  color: #fbf7f1;
}

.works-list {
  margin-top: 28rpx;
}

.works-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(43, 36, 29, 0.08);
}

.works-item-main {
  flex: 1;
  min-width: 0;
}

.works-item-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.2;
}

.works-item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #7a685c;
  font-size: 22rpx;
}

.works-favorite {
  border-radius: 999rpx;
  border: 1rpx solid rgba(29, 111, 95, 0.18);
  background: transparent;
  color: #1d6f5f;
}

.works-favorite-active {
  background: rgba(29, 111, 95, 0.1);
}

.works-empty {
  margin-top: 44rpx;
  padding: 40rpx 0;
}

.works-empty-title {
  font-size: 34rpx;
  font-weight: 600;
}

.works-empty-copy {
  margin: 14rpx 0 26rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a685c;
}
