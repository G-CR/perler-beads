page {
  min-height: 100%;
  background: #f4efe6;
  color: #2b241d;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.shell-page {
  padding: 32rpx 28rpx 44rpx;
}

.shell-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.shell-title {
  font-size: 56rpx;
  line-height: 1.05;
  font-weight: 700;
}

.shell-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7a685c;
}

.shell-section {
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(43, 36, 29, 0.08);
}

.shell-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.shell-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(29, 111, 95, 0.08);
  color: #1d6f5f;
  font-size: 24rpx;
}

.shell-button {
  width: 100%;
  border-radius: 24rpx;
  background: #1d6f5f;
  color: #fbf7f1;
  font-size: 28rpx;
  line-height: 1;
  padding: 28rpx 24rpx;
}
